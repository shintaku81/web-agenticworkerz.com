# ─────────────────────────────────────────────────────────────
# AgenticWorkerz — 環境変数サンプル
# .env.local にコピーして使用してください
# ─────────────────────────────────────────────────────────────

# サイト URL（本番: https://agenticworkerz.com）
NEXT_PUBLIC_SITE_URL=https://agenticworkerz.com

# Vercel Cron Job 認証シークレット
# Vercel ダッシュボードの Environment Variables に同じ値を設定すること
CRON_SECRET=your-cron-secret-here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend（メルマガ配信・お問い合わせ）
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Strapi CMS（Phase B）
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your-strapi-api-token-here

# Claude API（AI 改善ループ用）
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
